{{ '## ipmi_exporter' }}
{{ '# ' + ansible_managed }}
{{ '# Do not edit manually' }}

{% if lookup('ansible.builtin.vars', 'ipmi_exporter_options', default='')
  not in ['', [], '[]', None] %}
{% for i in lookup('ansible.builtin.vars', 'ipmi_exporter_options') %}
{% if loop['first'] %}
{{ (lookup('ansible.builtin.vars', 'ipmi_exporter_options_env_var', default='OPTIONS') | string) + '=\"' -}}
{% endif %}
{% if i['freeipmi_path'] is defined and i['freeipmi_path'] not in
  ['', [], '[]', None] %}
{{ ' --freeipmi.path=' + i['freeipmi_path'] -}}
{% endif %}
{% if i['web_listen_address'] is defined and i['web_listen_address'] not in
  ['', [], '[]', None] %}
{{ ' --web.listen-address=' + i['web_listen_address'] -}}
{% endif %}
{% if i['log_level'] is defined and i['log_level'] in ['debug', 'info', 'warn',
  'error'] %}
{{ ' --log.level=' + i['log_level'] -}}
{% endif %}
{% if i['log_format'] is defined and i['log_format'] in ['logfmt', 'json'] %}
{{ ' --log.format=' + i['log_format'] -}}
{% endif %}
{% if loop['last'] %}
{{- '\"' }}
{% endif %}
{% endfor %}
{% else %}
{{ (lookup('ansible.builtin.vars', 'ipmi_exporter_options_env_var', default='OPTIONS') | string) + '=""' }}
{% endif %}
